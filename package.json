{
  "name": "@descodify/mcp",
  "version": "0.1.1",
  "description": "Model Context Protocol server for Descodify — drive certified Portuguese invoicing, customers and products from your AI (Claude Desktop, Claude Code, Cursor, …).",
  "license": "MIT",
  "homepage": "https://descodify.pt/developers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/descodify/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/descodify/mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "descodify",
